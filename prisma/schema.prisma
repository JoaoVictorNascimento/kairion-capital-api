generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum AssetType {
  STOCK
  ETF
  CRYPTO
  FX
  INDEX
  FUND
  BOND
  OTHER
}

model Asset {
  id        String    @id @default(cuid())
  symbol    String
  name      String
  type      AssetType @default(OTHER)
  exchange  String
  currency  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  candles   Candle[]

  @@unique([symbol, exchange])
  @@index([symbol])
  @@index([exchange])
}

enum CandleInterval {
  DAY
}

model Candle {
  id          String         @id @default(cuid())
  assetId     String
  asset       Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  interval    CandleInterval
  bucketStart DateTime
  open        Decimal        @db.Decimal(18, 8)
  high        Decimal        @db.Decimal(18, 8)
  low         Decimal        @db.Decimal(18, 8)
  close       Decimal        @db.Decimal(18, 8)
  volume      Decimal        @db.Decimal(24, 2)
  createdAt   DateTime       @default(now())

  @@unique([assetId, interval, bucketStart])
  @@index([assetId, interval, bucketStart])
}