generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  portfolios   Portfolio[]
  backtests    BacktestRun[]
}

enum AssetType {
  STOCK
  ETF
  CRYPTO
  FX
  INDEX
  FUND
  BOND
  OTHER
}

model Asset {
  id              String           @id @default(cuid())
  symbol          String
  name            String
  type            AssetType        @default(OTHER)
  exchange        String
  currency        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  candles         Candle[]
  portfolioAssets PortfolioAsset[]
  backtestRuns    BacktestRun[]

  @@unique([symbol, exchange])
  @@index([symbol])
  @@index([exchange])
}

model Portfolio {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  assets      PortfolioAsset[]

  @@index([userId])
}

model PortfolioAsset {
  id            String    @id @default(cuid())
  portfolioId   String
  portfolio     Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  assetId       String
  asset         Asset     @relation(fields: [assetId], references: [id], onDelete: Restrict)
  targetWeight  Decimal?  @db.Decimal(12, 8)
  quantity      Decimal?  @db.Decimal(24, 8)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([portfolioId, assetId])
  @@index([portfolioId])
  @@index([assetId])
}

enum CandleInterval {
  DAY
}

enum BacktestStrategy {
  MOVING_AVERAGE_CROSSOVER
}

model BacktestRun {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId        String
  asset          Asset            @relation(fields: [assetId], references: [id], onDelete: Restrict)
  strategy       BacktestStrategy
  initialCapital Decimal          @db.Decimal(24, 4)
  periodStart    DateTime
  periodEnd      DateTime
  fastPeriod     Int
  slowPeriod     Int
  summary        Json
  series         Json
  createdAt      DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([assetId])
}

model Candle {
  id          String         @id @default(cuid())
  assetId     String
  asset       Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  interval    CandleInterval
  bucketStart DateTime
  open        Decimal        @db.Decimal(18, 8)
  high        Decimal        @db.Decimal(18, 8)
  low         Decimal        @db.Decimal(18, 8)
  close       Decimal        @db.Decimal(18, 8)
  volume      Decimal        @db.Decimal(24, 2)
  createdAt   DateTime       @default(now())

  @@unique([assetId, interval, bucketStart])
  @@index([assetId, interval, bucketStart])
}